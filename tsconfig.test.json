{
	"extends": "./tsconfig.json",
	"compilerOptions": {
		"target": "es2022",
		"module": "esnext",
		"moduleResolution": "bundler",
		"types": ["node"],
		"typeRoots": ["src/@types", "node_modules/@types"],
		"noEmit": true
	},
	"include": ["test/**/*", "vitest.config.ts"],
	"exclude": ["node_modules", "dist", "test/corpus/snapshots"]
}
